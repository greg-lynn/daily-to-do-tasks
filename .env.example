# ─────────────────────────────────────────────────────────────────────────────
#  Daily To-Do App — Environment Configuration
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Avoma ─────────────────────────────────────────────────────────────────────
#
# OPTION A — API Key (preferred, requires Avoma admin access)
#   Generate in: Avoma → Settings → Organization → Developer
#   Scope: "User – full access" (your meetings) or "Organization – limited access"
#   If AVOMA_API_KEY is set, it takes priority over email/password below.
#
AVOMA_API_KEY=

#
# OPTION B — Email + Password (no admin access required)
#   Use your normal Avoma login credentials.
#   The app will launch a headless Chrome browser, log in on your behalf,
#   and pull meeting data using the browser session.
#
#   NOTE: If your Avoma account uses Google/Microsoft SSO you won't have a
#   standalone Avoma password. You can set one via the "Forgot password" link
#   at https://app.avoma.com/login, then use it here.
#
AVOMA_EMAIL=glynn@rocketlane.com
AVOMA_PASSWORD=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Gmail example: use an App Password (Google Account → Security → App Passwords)
# Outlook/365 example: use SMTP_HOST=smtp.office365.com, PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password_here

# The email address that receives the daily summaries.
# Can be the same as SMTP_USER.
RECIPIENT_EMAIL=glynn@rocketlane.com

# ── Schedule ──────────────────────────────────────────────────────────────────
# Times in 24-hour HH:MM format, interpreted in TIMEZONE.
MORNING_TIME=08:00
EVENING_TIME=18:00

# Full IANA timezone name. See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/New_York

# ── Storage ───────────────────────────────────────────────────────────────────
# Path to the SQLite database file (created automatically on first run).
DB_PATH=tasks.db

# How many hours back the evening Avoma sync looks for completed meetings.
AVOMA_LOOKBACK_HOURS=24
