# ─────────────────────────────────────────────────────────────────────────────
#  Daily To-Do App — Environment Configuration
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Avoma ─────────────────────────────────────────────────────────────────────
#
# OPTION A — API Key (if your Avoma admin can generate one for you)
#   Admin goes to: Avoma → Settings → Organization → Developer
#   They create a "User – full access" key tied to your account and send it to you.
#   You don't need admin access yourself to USE a key, only to CREATE one.
#
AVOMA_API_KEY=

#
# OPTION B — One-time browser login (recommended for SSO / Google users)
#   No passwords stored. Run once:
#
#     python3 main.py avoma-login
#
#   A browser window opens — click "Sign in with Google" as normal.
#   The session is saved to .avoma_session/ and reused automatically.
#   Nothing needs to be set below for this option.
#
# OPTION C — Email + Password (only for non-SSO Avoma accounts)
#   If your account has a standalone Avoma password (not Google/Microsoft SSO):
#
AVOMA_EMAIL=glynn@rocketlane.com
AVOMA_PASSWORD=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Gmail example: use an App Password (Google Account → Security → App Passwords)
# Outlook/365 example: use SMTP_HOST=smtp.office365.com, PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password_here

# The email address that receives the daily summaries.
# Can be the same as SMTP_USER.
RECIPIENT_EMAIL=glynn@rocketlane.com

# ── Schedule ──────────────────────────────────────────────────────────────────
# Times in 24-hour HH:MM format, interpreted in TIMEZONE.
MORNING_TIME=08:00
EVENING_TIME=18:00

# Full IANA timezone name. See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/New_York

# ── Storage ───────────────────────────────────────────────────────────────────
# Path to the SQLite database file (created automatically on first run).
DB_PATH=tasks.db

# How many hours back the evening Avoma sync looks for completed meetings.
AVOMA_LOOKBACK_HOURS=24
